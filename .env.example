# =============================================================================
# .env.example — Safe configuration template for devsec_demo
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the real .env file to version control.
# Add .env to your .gitignore.
#
# Variable reference: devsec_demo/settings.py
# =============================================================================


# -----------------------------------------------------------------------------
# CORE — required in production, defaults exist for development
# -----------------------------------------------------------------------------

# Django secret key — signs sessions, CSRF tokens, and password-reset links.
# Generate a fresh key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# NEVER reuse the development key in production.
# NEVER check a real key into version control.
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-key

# Debug mode — MUST be False (or absent) in production.
# True only for local development. Debug mode leaks stack traces, SQL
# queries, and local variable values to any browser that triggers an error.
DJANGO_DEBUG=False

# Comma-separated list of domains/IPs that this Django instance serves.
# Example: DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# Wildcard (*) is rejected — list hostnames explicitly.
# Leave unset in development; falls back to localhost/127.0.0.1 when DEBUG=True.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com


# -----------------------------------------------------------------------------
# DATABASE — defaults to SQLite for development
# -----------------------------------------------------------------------------

# For production, use PostgreSQL or MySQL.
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=mydb
# DJANGO_DB_USER=myuser
# DJANGO_DB_PASSWORD=a-strong-database-password
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=5432

# SQLite (development default — no additional settings needed):
# DJANGO_DB_ENGINE=django.db.backends.sqlite3
# DJANGO_DB_NAME=/absolute/path/to/db.sqlite3


# -----------------------------------------------------------------------------
# EMAIL — defaults to console backend for development
# -----------------------------------------------------------------------------

# Production SMTP example:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com

# Development default (prints to console — no SMTP needed):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@mf-auth.local


# -----------------------------------------------------------------------------
# CACHE — defaults to in-process LocMemCache for development
# -----------------------------------------------------------------------------

# Multi-process / multi-server deployments MUST use a shared backend so that
# login-lockout state is visible across all workers.
#
# Redis example:
# DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
# DJANGO_CACHE_LOCATION=redis://127.0.0.1:6379/1

# Development default (in-process, no external server):
# DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# DJANGO_CACHE_LOCATION=mf-auth-cache


# -----------------------------------------------------------------------------
# SECURITY — transport layer (leave unset to use the built-in defaults)
# -----------------------------------------------------------------------------

# HSTS max-age in seconds (default: 31536000 = 1 year).
# Start with a small value (e.g. 3600) during initial HTTPS rollout,
# then increase to 31536000 once you are confident everything works over HTTPS.
# HSTS is automatically disabled (set to 0) when DJANGO_DEBUG=True.
# DJANGO_HSTS_SECONDS=31536000


# -----------------------------------------------------------------------------
# BRUTE-FORCE PROTECTION — tune per environment if needed
# -----------------------------------------------------------------------------

# Maximum consecutive failed login attempts before account lockout.
# LOGIN_MAX_ATTEMPTS=5

# Seconds an account stays locked after hitting the threshold.
# LOGIN_LOCKOUT_DURATION=900

# Rolling window (seconds) in which failed attempts are counted.
# LOGIN_ATTEMPT_WINDOW=900
